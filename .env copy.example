# =============================================================================
# CodeResidency — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Appwrite (Self-Hosted) ---
APPWRITE_ENDPOINT=http://appwrite/v1
APPWRITE_PROJECT_ID=coderesidency
APPWRITE_API_KEY=your_appwrite_server_api_key_here

# Appwrite Collection IDs (created during setup)
APPWRITE_DB_ID=main
APPWRITE_COLLECTION_USERS=users
APPWRITE_COLLECTION_MODULES=modules
APPWRITE_COLLECTION_SCENARIOS=scenarios
APPWRITE_COLLECTION_SESSIONS=sessions
APPWRITE_COLLECTION_CHAT_LOGS=chat_logs
APPWRITE_COLLECTION_CODE_SUBMISSIONS=code_submissions
APPWRITE_COLLECTION_TERMINAL_LOGS=terminal_logs
APPWRITE_COLLECTION_EVAL_REPORTS=evaluation_reports
APPWRITE_COLLECTION_ACHIEVEMENTS=achievements

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Backend (FastAPI) ---
BACKEND_SECRET_KEY=change_this_to_a_long_random_string_in_production
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_APPWRITE_ENDPOINT=http://localhost/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=coderesidency
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- Docker Sandbox Settings ---
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_QUOTA=50000
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_PIDS_LIMIT=50
